# =============================================================================
# VERCEL: Production environment only
# Dashboard → Settings → Environment Variables → check "Production"
# =============================================================================

# --- Email (shared across tiers is OK; same Resend key) ---
RESEND_API_KEY=
OWNER_EMAIL=thenurturedoven@gmail.com
EMAIL_FROM_ADDRESS=order@thenurturedoven.com
EMAIL_FROM_NAME=The Nurtured Oven
EMAIL_REPLY_TO=order@thenurturedoven.com

# --- Square PRODUCTION (live payments) ---
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
SQUARE_ENVIRONMENT=production

# --- Webhook (Square Production app → Webhooks) ---
# URL must match exactly. Event: payment.updated only.
SQUARE_WEBHOOK_SIGNATURE_KEY=
SQUARE_WEBHOOK_NOTIFICATION_URL=

# --- Redis Cloud (webhook idempotency — prevents duplicate confirmation emails) ---
# redis.io/cloud → your database → Connect → copy the rediss:// URL
REDIS_URL=

# --- Admin (password-protected /admin dashboard) ---
ADMIN_PASSWORD=
# Menu photo uploads on Vercel (Vercel → Storage → Blob)
# BLOB_READ_WRITE_TOKEN=

# --- Google Sheets (paid order tracker + weekly menu) ---
# Spreadsheet ID is from https://docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit
GOOGLE_SHEET_ID=1gBJMFJk0KGRdbnFrdBrQP1iZE0yjdlHwIrLOh5sFgLg
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
# Optional tab ranges (defaults: Orders!A:R, Order Line Items!A:M, Menu!A:L)
# GOOGLE_SHEETS_ORDERS_RANGE=Orders!A:R
# GOOGLE_SHEETS_LINE_ITEMS_RANGE=Order Line Items!A:M
# GOOGLE_SHEETS_MENU_RANGE=Menu!A:L
# Legacy alias for orders range only:
# GOOGLE_SHEETS_RANGE=Orders!A:R

# --- Public URL (custom domain) ---
NEXT_PUBLIC_APP_URL=https://thenurturedoven.com

# --- Ordering (optional kill switch) ---
# Unset or false = real weekly window (Fri 9 AM – Wed noon ET). Set true to close ordering on this deploy.
# WEEKLY_ORDERING_DISABLED=true
