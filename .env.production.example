# =============================================================================
# VERCEL: Production environment only
# Dashboard → Settings → Environment Variables → check "Production"
# =============================================================================

# --- Email (shared across tiers is OK; same Resend key) ---
RESEND_API_KEY=
OWNER_EMAIL=thenurturedoven@gmail.com
EMAIL_FROM_ADDRESS=thenurturedoven@gmail.com
EMAIL_FROM_NAME=The Nurtured Oven
EMAIL_REPLY_TO=thenurturedoven@gmail.com

# --- Square PRODUCTION (live payments) ---
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
SQUARE_ENVIRONMENT=production

# --- Webhook (Square Production app → Webhooks) ---
# URL must match exactly. Event: payment.updated only.
SQUARE_WEBHOOK_SIGNATURE_KEY=
SQUARE_WEBHOOK_NOTIFICATION_URL=https://thenurturedoven.com/api/webhooks/square

# --- Public URL (custom domain) ---
NEXT_PUBLIC_APP_URL=https://thenurturedoven.com
