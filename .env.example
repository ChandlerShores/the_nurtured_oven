# Email — Resend (https://resend.com)
RESEND_API_KEY=

# The email address where order inquiries should be sent.
OWNER_EMAIL=hello@thenurturedoven.com

# Square — https://developer.squareup.com/apps
# Local dev: sandbox token + sandbox location. Live site: production token + location.
# SQUARE_APPLICATION_ID=  # optional; not used by Payment Links checkout today
SQUARE_ACCESS_TOKEN=
SQUARE_APPLICATION_SECRET=
SQUARE_LOCATION_ID=
# sandbox | production (defaults to sandbox)
SQUARE_ENVIRONMENT=sandbox

# Webhook — create at Square Developer Dashboard → Webhooks
# Subscribe to payment.updated. URL must match exactly (e.g. https://yoursite.com/api/webhooks/square)
SQUARE_WEBHOOK_SIGNATURE_KEY=
SQUARE_WEBHOOK_NOTIFICATION_URL=

# Public site URL (used for checkout redirect + webhook verification)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Dev only — override ordering window day (0=Sun … 4=Thu … 6=Sat). Requires NODE_ENV=development.
# ORDERING_TEST_WEEKDAY=4
# ORDERING_TEST_HOUR=12
# ORDERING_TEST_MINUTE=0
