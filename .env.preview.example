# =============================================================================
# VERCEL: Preview environment only (branch deploys, PR previews)
# Dashboard → Settings → Environment Variables → check "Preview"
# =============================================================================

# --- Email ---
RESEND_API_KEY=
OWNER_EMAIL=thenurturedoven@gmail.com
EMAIL_FROM_ADDRESS=order@thenurturedoven.com
EMAIL_FROM_NAME=The Nurtured Oven
EMAIL_REPLY_TO=order@thenurturedoven.com

# --- Square SANDBOX (test payments on preview URLs) ---
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
SQUARE_ENVIRONMENT=sandbox

# --- Webhook (Square SANDBOX app → separate subscription for preview URL) ---
# Use your preview URL, e.g. https://your-project-git-branch-org.vercel.app/api/webhooks/square
# Or omit both keys on preview if you only test emails via /contact (no post-payment webhook).
SQUARE_WEBHOOK_SIGNATURE_KEY=
SQUARE_WEBHOOK_NOTIFICATION_URL=

# --- Redis Cloud (webhook idempotency — optional on preview) ---
REDIS_URL=

# --- Admin (optional on preview) ---
# 12+ characters; use a password manager
ADMIN_PASSWORD=
# Recommended: 32+ random chars (openssl rand -base64 32)
# ADMIN_SESSION_SECRET=
# Menu photo uploads on Vercel (optional; local dev writes to public/images/menu/)
# BLOB_READ_WRITE_TOKEN=

# --- Google Sheets (optional on preview) ---
GOOGLE_SHEET_ID=1gBJMFJk0KGRdbnFrdBrQP1iZE0yjdlHwIrLOh5sFgLg
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
# Optional tab ranges (defaults: Orders!A:R, Order Line Items!A:M, Menu!A:L)
# GOOGLE_SHEETS_ORDERS_RANGE=Orders!A:R
# GOOGLE_SHEETS_LINE_ITEMS_RANGE=Order Line Items!A:M
# GOOGLE_SHEETS_MENU_RANGE=Menu!A:L
# GOOGLE_SHEETS_CUSTOMER_EMAILS_RANGE=Customer Emails!A:J
# GOOGLE_SHEETS_PRODUCT_COSTS_RANGE=Product Costs!A:G
# GOOGLE_SHEETS_WEEKLY_EXPENSES_RANGE=Weekly Expenses!A:J
# FINANCIAL_LABOR_RATE_PER_HOUR=22
# FINANCIAL_SQUARE_FEE_BPS=290
# FINANCIAL_SQUARE_FEE_FIXED_CENTS=30

# --- Ordering (optional; same as production) ---
# WEEKLY_ORDERING_DISABLED=true

# --- Public URL ---
# Option A: leave empty — app uses https://VERCEL_URL per deploy automatically.
# Option B: set a fixed staging URL if you use one.
# NEXT_PUBLIC_APP_URL=
